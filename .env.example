# =============================================================================
# helpdesk-ai — .env.example
# Copy to .env and fill in the blanks. Never commit .env.
# =============================================================================

# --- Shared security DB (sso-manager) ---
SECURITY_DB_HOST=tasks.infra_postgres
SECURITY_DB_PORT=5432
SECURITY_DB_USER=pgadmin
SECURITY_DB_PASSWORD=<pgadmin-password>
SECURITY_DB_NAME=security
SECURITY_SCHEMA=public         # schema inside SECURITY_DB_NAME that holds users/groups

# --- Helpdesk-local Postgres ---
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=<strong-random>
POSTGRES_DB=helpdesk
DATABASE_URL=postgresql+asyncpg://helpdesk:<password>@postgres:5432/helpdesk

# --- Schemas ---
HELPDESK_SCHEMA=helpdesk
RAG_SCHEMA=helpdesk_rag

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<strong-random>
MINIO_BUCKET=helpdesk-attachments

# --- ClamAV ---
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# --- AI providers ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
AI_FALLBACK_ENABLED=false

# --- Session / security ---
SECRET_KEY=<64-char-random>
CSRF_SECRET=<64-char-random>
SESSION_COOKIE_NAME=__Host-sds_session

# --- Email (SMTP) ---
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
SMTP_USER=<user>@<domain>
SMTP_PASSWORD=<password>
MAIL_FROM=<user>@<domain>

# --- RBAC bootstrap (Sprint 0 only, replaced by role_overrides in Sprint 2) ---
# Comma-separated UUIDs (users.uuid from security.users) to promote to it_admin
# regardless of group membership. Leave blank in production after Sprint 2.
BOOTSTRAP_ADMIN_UUIDS=<uuid1>,<uuid2>  # promotes these users to it_admin
                                        # until helpdesk.role_overrides lands

# --- App ---
ENV=development
LOG_LEVEL=INFO
